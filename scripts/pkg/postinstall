#!/bin/bash
# Ongeul .pkg postinstall script
# Installer passes $2 = install location (e.g. / for system, user home for per-user)

BUNDLE_ID="io.github.hiking90.inputmethod.Ongeul"
INSTALL_LOCATION="$2"

# 앱이 재서명되면 기존 TCC 항목이 무효화되므로 리셋
tccutil reset Accessibility "$BUNDLE_ID" 2>/dev/null || true

# 설치 위치에 따라 실제 .app 경로 결정
if [[ "$INSTALL_LOCATION" == /Library/* || "$INSTALL_LOCATION" == "/" ]]; then
    APP_PATH="/Library/Input Methods/Ongeul.app"
else
    APP_PATH="${INSTALL_LOCATION}/Library/Input Methods/Ongeul.app"
fi

# 콘솔 사용자 확인 (TIS 호출은 사용자 세션에서 실행되어야 함)
CONSOLE_USER=$( /usr/sbin/scutil <<< "show State:/Users/ConsoleUser" | awk '/Name :/ { print $3 }' )

# 최초 설치 시 1회: 한/영 입력 소스를 TIS에 등록.
# 이후 사용자가 시스템 설정에서 제거하면 다시 등록되지 않는다 (Info.plist의 tsInputModeDefaultStateKey=false).
if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "loginwindow" ] && [ -x "$APP_PATH/Contents/MacOS/Ongeul" ]; then
    /usr/bin/sudo -u "$CONSOLE_USER" \
        "$APP_PATH/Contents/MacOS/Ongeul" --enable-input-sources || true
fi

exit 0
