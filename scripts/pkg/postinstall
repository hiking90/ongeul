#!/bin/bash
# Ongeul .pkg postinstall script

BUNDLE_ID="io.github.hiking90.inputmethod.Ongeul"

# 앱이 재서명되면 기존 TCC 항목이 무효화되므로 리셋
tccutil reset Accessibility "$BUNDLE_ID" 2>/dev/null || true

# Accessibility 권한 안내는 앱 첫 실행 시 macOS 시스템 다이얼로그로 표시됨
# (AXIsProcessTrustedWithOptions in OngeulInputController.activateServer)

exit 0
