<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>io.github.hiking90.inputmethod.Ongeul</string>

    <key>CFBundleName</key>
    <string>Ongeul</string>

    <key>CFBundleDisplayName</key>
    <string>Ongeul</string>

    <key>CFBundleDevelopmentRegion</key>
    <string>ko</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundleShortVersionString</key>
    <string>0.2.0</string>

    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>Ongeul</string>

    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <key>LSUIElement</key>
    <true/>

    <key>InputMethodConnectionName</key>
    <string>io.github.hiking90.inputmethod.Ongeul_Connection</string>

    <key>InputMethodServerControllerClass</key>
    <string>Ongeul.OngeulInputController</string>

    <key>InputMethodServerDelegateClass</key>
    <string>Ongeul.OngeulInputController</string>

    <key>ComponentInputModeDict</key>
    <dict>
        <key>tsInputModeListKey</key>
        <dict>
            <key>io.github.hiking90.inputmethod.Ongeul</key>
            <dict>
                <key>TISIntendedLanguage</key>
                <string>ko</string>
                <key>TISInputSourceID</key>
                <string>io.github.hiking90.inputmethod.Ongeul</string>
                <key>tsInputModeMenuIconFileKey</key>
                <string>icon_menubar.tiff</string>
                <key>tsInputModeAlternateMenuIconFileKey</key>
                <string>icon_ko.tiff</string>
                <key>tsInputModePaletteIconFileKey</key>
                <string>icon_ko.tiff</string>
                <key>tsInputModeIsVisibleKey</key>
                <true/>
                <key>tsInputModeScriptKey</key>
                <string>smKorean</string>
                <!-- tsInputModePrimaryInScriptKey 는 의도적으로 제거됨.
                     true 설정 시 macOS가 "Korean 스크립트의 primary IME"로 간주하여
                     사용자가 삭제해도 logout/login 시 최초 1회 자동 재활성화하는 부작용이 있음.
                     Ongeul은 설치 시 postinstall에서 --enable-input-sources로 명시적 등록하므로
                     primary 플래그 없이도 UX에 영향 없음. -->
                <key>TISIconIsTemplate</key>
                <true/>
                <key>tsInputModeDefaultStateKey</key>
                <false/>
            </dict>

            <!-- English 모드 -->
            <key>io.github.hiking90.inputmethod.Ongeul.English</key>
            <dict>
                <key>TISIntendedLanguage</key>
                <string>en</string>
                <key>TISInputSourceID</key>
                <string>io.github.hiking90.inputmethod.Ongeul.English</string>
                <key>tsInputModeMenuIconFileKey</key>
                <string>icon_en.tiff</string>
                <key>tsInputModeAlternateMenuIconFileKey</key>
                <string>icon_en.tiff</string>
                <key>tsInputModePaletteIconFileKey</key>
                <string>icon_en.tiff</string>
                <key>tsInputModeIsVisibleKey</key>
                <true/>
                <key>tsInputModeScriptKey</key>
                <string>smUnicodeScript</string>
                <key>TISIconIsTemplate</key>
                <true/>
                <key>tsInputModeDefaultStateKey</key>
                <false/>
            </dict>
        </dict>
        <!-- tsVisibleInputModeOrderedArrayKey 는 의도적으로 제거됨.
             이전엔 Korean만 단독 리스트되어 있어 macOS가 "이 IME의 대표 Korean 모드"로
             인식, 사용자가 제거해도 logout/login 시 재활성화하는 부작용이 관찰됨.
             각 모드의 tsInputModeIsVisibleKey=true 가 "+" 추가 다이얼로그 노출을 담당하므로
             이 배열은 기능 손실 없이 제거 가능. -->
    </dict>

    <key>tsInputMethodCharacterRepertoireKey</key>
    <array>
        <string>Hang</string>
        <string>Latn</string>
    </array>

    <key>tsInputMethodIconFileKey</key>
    <string>icon_ko.tiff</string>

    <key>TISIconIsTemplate</key>
    <true/>

    <key>TISIconLabels</key>
    <dict>
        <key>Primary</key>
        <string>온</string>
    </dict>

</dict>
</plist>
